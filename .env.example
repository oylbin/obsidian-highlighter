# -----------------------------------------------------------------------------
# Local development environment variables for obsidian-highlighter.
# Copy this file to `.env` and fill in the values before running `make install`.
# -----------------------------------------------------------------------------

# Path to the plugin folder inside your Obsidian test vault.
# Used by `make install` to deploy main.js / styles.css / manifest.json.
#
# Examples:
#   Windows (MINGW64): VAULT_PLUGIN_PATH=/c/Users/me/ObsidianVault/.obsidian/plugins/obsidian-highlighter
#   macOS:             VAULT_PLUGIN_PATH=/Users/me/ObsidianVault/.obsidian/plugins/obsidian-highlighter
#   Linux:             VAULT_PLUGIN_PATH=/home/me/ObsidianVault/.obsidian/plugins/obsidian-highlighter
VAULT_PLUGIN_PATH=
